# URL del backend usato dall'app.
# Expo "inlina" le variabili EXPO_PUBLIC_* al momento del bundle:
# dopo OGNI modifica a questo file riavvia Expo pulendo la cache:
#   npx expo start -c
#
# La porta dipende da come avvii il backend:
#   - Docker (nginx davanti):        porta 8080
#   - Locale (npm run backend:dev):  porta 4000
# L'IP deve essere quello del Mac SULLA RETE ATTUALE (cambia se cambi WiFi/hotspot).
# IP attuale del Mac: 172.19.207.167

EXPO_PUBLIC_HEMORA_API_URL=http://172.19.207.167:8080

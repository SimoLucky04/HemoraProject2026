# URL del backend usato dall'app.
# Expo "inlina" le variabili EXPO_PUBLIC_* al momento del bundle:
# dopo OGNI modifica a questo file riavvia Expo pulendo la cache:
#   npx expo start -c
#
# --- Tunnel Cloudflare (CONSIGLIATO) --------------------------------------
# Funziona da QUALSIASI rete (anche WiFi universitaria con client isolation) e
# da qualsiasi dispositivo, senza dipendere dall'IP del Mac.
#   npm run docker:tunnel       # avvia backend + nginx + tunnel
#   npm run docker:tunnel:url   # stampa l'URL https://....trycloudflare.com
# ⚠️ L'URL del tunnel free CAMBIA a ogni riavvio del tunnel: quando cambia,
#    aggiorna la riga qui sotto e rilancia `npx expo start -c`.
#
# --- Alternativa: stessa LAN (no client isolation) ------------------------
#   IP del Mac (cambia se cambi WiFi/hotspot):  ipconfig getifaddr en0
#   poi usa:  http://<IP-del-Mac>:8080   (Docker/nginx)  oppure :4000 (backend:dev)

EXPO_PUBLIC_HEMORA_API_URL=https://social-achieved-much-partial.trycloudflare.com

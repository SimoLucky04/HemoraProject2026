# URL del backend usato dall'app. Copia questo file in `.env` e adatta IP/porta.
# Dopo ogni modifica riavvia Expo pulendo la cache:  npx expo start -c
#
# IP = indirizzo del PC sulla rete (NON "localhost" da telefono fisico).
# Porta:  Docker (nginx) -> 8080   |   Locale (npm run backend:dev) -> 4000
EXPO_PUBLIC_HEMORA_API_URL=http://192.168.1.10:8080

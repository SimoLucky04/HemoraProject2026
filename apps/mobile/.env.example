# URL del backend usato dall'app. Copia questo file in `.env` e adatta il valore.
# Dopo ogni modifica riavvia Expo pulendo la cache:  npx expo start -c
#
# Scegli UNA delle opzioni:
#
# 1) Tunnel Cloudflare (CONSIGLIATO, funziona da qualsiasi rete):
#      npm run docker:tunnel && npm run docker:tunnel:url
#    EXPO_PUBLIC_HEMORA_API_URL=https://<random>.trycloudflare.com
#
# 2) Stessa WiFi del PC (IP da `ipconfig getifaddr en0`):
#    Porta:  Docker (nginx) -> 8080   |   Locale (npm run backend:dev) -> 4000
EXPO_PUBLIC_HEMORA_API_URL=http://192.168.1.10:8080
